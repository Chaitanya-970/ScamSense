{
  "manifest_version": 3,
  "name": "ScamSense: Real-Time Shield",
  "version": "1.0",
  "description": "Analyzes WhatsApp and SMS conversations to detect scams.",
  "permissions": ["storage", "scripting"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://messages.google.com/*",
    "https://scamsense-rzq0.onrender.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*",
        "https://messages.google.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}